yarn-error.log*
logs/
*.log

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE-specific folders
.vscode/
.idea/
*.swp
*.swo

# OS-specific files
.DS_Store
Thumbs.db